# =============================================================================
# Me Retrouver — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# =============================================================================

# ── Booking (Calendly, Cal.com, etc.) ───────────────────────────────────────
# URL du lien de prise de rendez-vous
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/votre-compte

# ── Google Analytics ────────────────────────────────────────────────────────
# ID de mesure GA4 (format G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Sentry (optionnel) ─────────────────────────────────────────────────────
# Si tu n'utilises pas Sentry, laisse vide
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Site ────────────────────────────────────────────────────────────────────
# Ne pas modifier — utilisé par le build
NEXT_PUBLIC_SITE_URL=https://meretrouver.fr
